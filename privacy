/* ── Language engine ── */
(function(){
  function detectLang(){
    var stored=localStorage.getItem("sleepy-lang");
    if(stored==="en"||stored==="fr") return stored;
    var nav=(navigator.language||navigator.userLanguage||"en").toLowerCase();
    return nav.startsWith("fr")?"fr":"en";
  }
  function applyLang(lang){
    localStorage.setItem("sleepy-lang",lang);
    document.documentElement.lang=lang;
    var t=TRANSLATIONS[lang];
    document.querySelectorAll("[data-i18n]").forEach(function(el){
      var key=el.getAttribute("data-i18n");
      if(t[key]!=null) el.innerHTML=t[key];
    });
    document.querySelectorAll(".lang-btn").forEach(function(btn){
      var active=btn.getAttribute("data-lang")===lang;
      btn.classList.toggle("active",active);
      btn.setAttribute("aria-checked",active?"true":"false");
    });
    if(lang==="fr"){
      document.title="Sleepy \u2014 Politique de confidentialit\u00e9";
      var d=document.querySelector('meta[name="description"]');if(d)d.content="Politique de confidentialit\u00e9 de Sleepy. Z\u00e9ro collecte de donn\u00e9es, z\u00e9ro tracking. Vos donn\u00e9es restent sur votre appareil.";
    }else{
      document.title="Sleepy \u2014 Privacy Policy";
      var d=document.querySelector('meta[name="description"]');if(d)d.content="Sleepy Privacy Policy. Zero data collection, zero tracking, zero analytics. Your sleep data stays on your device.";
    }
  }
  document.querySelectorAll(".lang-btn").forEach(function(btn){
    btn.addEventListener("click",function(){applyLang(btn.getAttribute("data-lang"))});
  });
  applyLang(detectLang());

  /* ── Nav scroll effect ── */
  var nav=document.querySelector(".nav");
  var scrolled=false;
  window.addEventListener("scroll",function(){
    var s=window.scrollY>32;
    if(s!==scrolled){scrolled=s;nav.classList.toggle("scrolled",s)}
  },{passive:true});

  /* ── Intersection observer fade-in ── */
  if("IntersectionObserver" in window){
    var io=new IntersectionObserver(function(entries){
      entries.forEach(function(e){if(e.isIntersecting){e.target.classList.add("visible");io.unobserve(e.target)}});
    },{threshold:0.12});
    document.querySelectorAll(".fade-in").forEach(function(el){io.observe(el)});
  }else{
    document.querySelectorAll(".fade-in").forEach(function(el){el.classList.add("visible")});
  }
})();
</script>
</body>
